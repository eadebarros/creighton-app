# Copy to .env and fill in. EXPO_PUBLIC_* vars are inlined into the client
# bundle by design — only ever put the PUBLISHABLE Clerk key here, never the
# secret key (that one stays backend-only, see packages/backend/.env.example).

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# The @creighton/backend base URL. Use your Railway domain for a real device
# (localhost won't resolve from a phone); use your Mac's LAN IP for local dev
# against `npm run dev --workspace=@creighton/backend`.
EXPO_PUBLIC_API_BASE_URL="https://your-app.up.railway.app"
