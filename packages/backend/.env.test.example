# Copy to .env.test — never commit the real file (already gitignored).
# Points at a DEDICATED SCHEMA on the same Railway Postgres instance as dev,
# so `npm test` never touches real dev/prod data. Truncated between tests
# (see test/setup.ts) — never point this at a database you care about.

DATABASE_URL="postgresql://user:password@host:port/railway?schema=test"

# Same Clerk test-mode keys as .env — fine to reuse, Clerk's test mode already
# isolates test users from real ones.
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."

PORT=3001
