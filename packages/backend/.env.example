# Copy to .env and fill in — never commit the real file (already gitignored).

# Railway Postgres connection string (dev). Get it from your Railway project's Postgres service "Connect" tab.
DATABASE_URL="postgresql://user:password@host:port/railway"

# A second connection string pointed at a dedicated schema for automated tests,
# e.g. same DATABASE_URL with `?schema=test` appended, or `-c search_path=test`.
DATABASE_URL_TEST="postgresql://user:password@host:port/railway?schema=test"

# From your Clerk dashboard (Configure > API Keys).
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."

PORT=3000
